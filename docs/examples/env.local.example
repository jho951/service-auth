# IntelliJ/host local runtime example.
# Copy this file to .env.local at the repository root.

SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8082

# JWT
AUTH_JWT_SECRET=change-this-local-auth-jwt-secret-change-this-local-auth-jwt-secret
AUTH_JWT_AUDIENCE=block-service
AUTH_ACCESS_EXPIRATION=1200
AUTH_REFRESH_EXPIRATION=604800
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_SECURE=false

# Internal API
INTERNAL_API_KEY=local-internal-api-key

# SSO
SSO_GITHUB_CLIENT_ID=change-this-github-client-id
SSO_GITHUB_CLIENT_SECRET=change-this-github-client-secret
SSO_GITHUB_CALLBACK_URI=http://localhost:8082/login/oauth2/code/github
SSO_SESSION_COOKIE_NAME=sso_session
SSO_SESSION_COOKIE_SECURE=false
SSO_SESSION_COOKIE_SAME_SITE=Lax
SSO_STATE_TTL_SECONDS=300
SSO_TICKET_TTL_SECONDS=120
SSO_SESSION_TTL_SECONDS=604800
SSO_ADMIN_ORIGIN=http://localhost:5173
SSO_ADMIN_CALLBACK_URI=http://localhost:5173/admin/auth/callback
SSO_ADMIN_IP_GUARD_ENABLED=false
SSO_ADMIN_IP_GUARD_DEFAULT_ALLOW=false
SSO_ADMIN_IP_RULES=127.0.0.1,::1

# Local default uses in-memory H2 so IntelliJ can start without Docker MySQL.
DB_DRIVER=org.h2.Driver
MYSQL_URL=jdbc:h2:mem:authdb;MODE=MySQL;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
MYSQL_USER=sa
MYSQL_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Platform security
PLATFORM_SECURITY_ADMIN_ALLOW_CIDRS=127.0.0.1/32,::1/128
PLATFORM_SECURITY_INTERNAL_ALLOW_CIDRS=127.0.0.1/32,::1/128
PLATFORM_SECURITY_RATE_LIMIT_AUTH_LOGIN_REQUESTS=10
PLATFORM_SECURITY_RATE_LIMIT_AUTH_LOGIN_WINDOW_SECONDS=60
PLATFORM_SECURITY_RATE_LIMIT_AUTH_REFRESH_REQUESTS=20
PLATFORM_SECURITY_RATE_LIMIT_AUTH_REFRESH_WINDOW_SECONDS=60

# User service
USER_SERVICE_BASE_URL=http://localhost:8083
USER_SERVICE_JWT_ISSUER=auth-service
USER_SERVICE_JWT_AUDIENCE=user-service
USER_SERVICE_JWT_SUBJECT=auth-service
USER_SERVICE_JWT_SCOPE=internal
USER_SERVICE_JWT_TTL_SECONDS=60
USER_SERVICE_JWT_SECRET=change-this-to-the-user-service-shared-hmac-secret

# Platform governance
PLATFORM_GOVERNANCE_ENABLED=true
PLATFORM_GOVERNANCE_AUDIT_ENABLED=true
PLATFORM_GOVERNANCE_POLICY_ENGINE_STORE=MEMORY
PLATFORM_GOVERNANCE_POLICY_ENGINE_FILE_PATH=
PLATFORM_GOVERNANCE_POLICY_ENGINE_CACHE_TTL_MILLIS=3000
PLATFORM_GOVERNANCE_ENGINE_STRICT=false
PLATFORM_GOVERNANCE_VIOLATION_ACTION=DENY
PLATFORM_GOVERNANCE_VIOLATION_HANDLER_FAILURE_FATAL=false
PLATFORM_GOVERNANCE_OPERATIONAL_FAIL_FAST_ENABLED=true
PLATFORM_GOVERNANCE_OPERATIONAL_PRODUCTION_PROFILES=prod
PLATFORM_GOVERNANCE_OPERATIONAL_REQUIRE_AUDIT_SINK_IN_PRODUCTION=true
PLATFORM_GOVERNANCE_OPERATIONAL_REQUIRE_POLICY_CONFIG_IN_ENFORCING_MODE=true
PLATFORM_GOVERNANCE_OPERATIONAL_REQUIRE_FATAL_HANDLER_FAILURES_IN_PRODUCTION=true
