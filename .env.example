SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8081
AUTH_SERVICE_HOST_BIND=0.0.0.0
AUTH_SERVICE_HOST_PORT=8081
SERVICE_SHARED_NETWORK=service-backbone-shared

MYSQL_HOST=auth-mysql
MYSQL_PORT=3306
MYSQL_DB=auth_service_db
MYSQL_USER=auth_user
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me
MYSQL_URL=jdbc:mysql://auth-mysql:3306/auth_service_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# dev single-host compose 기본값은 central-redis alias를 사용합니다.
# prod에서 서비스를 EC2별로 분리하면 Redis private DNS/IP 또는 관리형 endpoint로 override해야 합니다.
REDIS_HOST=central-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

AUTH_JWT_SECRET=change-me-to-a-long-random-secret
INTERNAL_API_KEY=local-internal-api-key

SSO_GITHUB_CLIENT_ID=local-github-client-id
SSO_GITHUB_CLIENT_SECRET=local-github-client-secret
SSO_GITHUB_CALLBACK_URI=http://127.0.0.1:8080/v1/login/oauth2/code/github
SSO_EXPLAIN_ORIGIN=http://127.0.0.1:3000
SSO_EXPLAIN_CALLBACK_URI=http://127.0.0.1:3000/auth/callback
SSO_EDITOR_ORIGIN=http://127.0.0.1:5173
SSO_EDITOR_CALLBACK_URI=http://127.0.0.1:5173/auth/callback
SSO_ADMIN_ORIGIN=http://127.0.0.1:3003
SSO_ADMIN_CALLBACK_URI=http://127.0.0.1:3003/admin/auth/callback
SSO_ADMIN_IP_GUARD_ENABLED=false

# dev single-host compose 기본값은 user-service alias를 사용합니다.
# prod에서 서비스를 EC2별로 분리하면 user-service private DNS/IP로 override해야 합니다.
USER_SERVICE_BASE_URL=http://user-service:8082
USER_SERVICE_JWT_AUDIENCE=user-service
USER_SERVICE_JWT_SCOPE=internal

GITHUB_ACTOR=
GH_TOKEN=
