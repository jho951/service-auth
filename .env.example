SSO_EXPLAIN_ORIGIN=http://localhost:3000
SSO_EXPLAIN_CALLBACK_URI=http://localhost:3000/auth/callback
SSO_EDITOR_ORIGIN=http://localhost:5173
SSO_EDITOR_CALLBACK_URI=http://localhost:5173/auth/callback
SSO_ADMIN_ORIGIN=http://localhost:3003
SSO_ADMIN_CALLBACK_URI=http://localhost:3003/admin/auth/callback
SSO_ADMIN_IP_GUARD_ENABLED=false

